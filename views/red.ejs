<% layout('boilerplate') %>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Cormorant Garamond', serif;
            background-color: #FAFAF8;
            color: #1A1A1A;
            min-height: 100vh;
        }

        img {
            display: block;
        }

        button {
            font-family: 'Cormorant Garamond', serif;
        }

        /* Navigation */
        nav {
            position: sticky;
            top: 0;
            background-color: #FFFFFF;
            border-bottom: 1px solid #E8E8E5;
            z-index: 1000;
            backdrop-filter: blur(10px);
        }

        .nav-container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 24px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            font-size: 28px;
            font-weight: 300;
            letter-spacing: 3px;
            text-transform: uppercase;
            cursor: pointer;
        }

        .nav-icons {
            display: flex;
            gap: 28px;
            align-items: center;
        }

        .nav-icons i {
            cursor: pointer;
        }

        .back-btn {
            display: flex;
            align-items: center;
            gap: 8px;
            background: none;
            border: none;
            cursor: pointer;
            font-size: 15px;
            letter-spacing: 1px;
            color: #1A1A1A;
            transition: all 0.3s ease;
        }

        .back-btn:hover {
            color: #6A6A6A;
        }

        /* Breadcrumb */
        .breadcrumb {
            max-width: 1400px;
            margin: 0 auto;
            padding: 32px 40px 0;
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 14px;
            color: #8A8A8A;
            letter-spacing: 0.5px;
        }

        .breadcrumb a {
            color: #8A8A8A;
            text-decoration: none;
            cursor: pointer;
            transition: color 0.3s ease;
        }

        .breadcrumb a:hover {
            color: #1A1A1A;
        }

        .breadcrumb span {
            color: #1A1A1A;
        }

        /* Hero Section */
        .product-hero {
            max-width: 1400px;
            margin: 0 auto;
            padding: 48px 40px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 80px;
            align-items: start;
        }

        .hero-image {
            position: sticky;
            top: 100px;
        }

        .hero-image img {
            width: 100%;
            border: 1px solid #E8E8E5;
        }

        .hero-content {
            padding-top: 40px;
        }

        .category-badge {
            display: inline-block;
            font-size: 12px;
            color: #8A8A8A;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            margin-bottom: 16px;
            padding: 8px 16px;
            border: 1px solid #E8E8E5;
            background-color: #FFFFFF;
        }

        .product-title {
            font-size: 56px;
            font-weight: 300;
            letter-spacing: 1px;
            margin: 0 0 24px 0;
            line-height: 1.2;
        }

        .product-rating {
            display: flex;
            gap: 4px;
            margin-bottom: 32px;
            align-items: center;
        }

        .rating-text {
            margin-left: 12px;
            font-size: 14px;
            color: #6A6A6A;
            letter-spacing: 0.5px;
        }

        .product-price {
            font-size: 48px;
            font-weight: 400;
            letter-spacing: 1px;
            margin-bottom: 40px;
        }

        .price-note {
            font-size: 14px;
            color: #6A6A6A;
            margin-top: 12px;
            letter-spacing: 0.5px;
        }

        .cta-section {
            display: flex;
            gap: 16px;
            margin-bottom: 48px;
            padding-bottom: 48px;
            border-bottom: 1px solid #E8E8E5;
        }

        .cta-primary {
            flex: 1;
            padding: 18px 40px;
            background-color: #1A1A1A;
            color: #FFFFFF;
            border: none;
            cursor: pointer;
            font-size: 14px;
            letter-spacing: 2px;
            text-transform: uppercase;
            transition: all 0.3s ease;
        }

        .cta-primary:hover {
            background-color: #3A3A3A;
        }

        .cta-secondary {
            padding: 18px 40px;
            background-color: #FFFFFF;
            color: #1A1A1A;
            border: 1px solid #1A1A1A;
            cursor: pointer;
            font-size: 14px;
            letter-spacing: 2px;
            text-transform: uppercase;
            transition: all 0.3s ease;
        }

        .cta-secondary:hover {
            background-color: #1A1A1A;
            color: #FFFFFF;
        }

        /* Features Section */
        .features-section {
            margin-bottom: 48px;
        }

        .section-title {
            font-size: 24px;
            font-weight: 400;
            letter-spacing: 1px;
            margin-bottom: 24px;
        }

        .features-grid {
            display: grid;
            gap: 20px;
        }

        .feature-item {
            display: flex;
            align-items: start;
            gap: 16px;
            padding: 20px;
            background-color: #FFFFFF;
            border: 1px solid #E8E8E5;
        }

        .feature-icon {
            flex-shrink: 0;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: #FAFAF8;
        }

        .feature-content h4 {
            font-size: 16px;
            font-weight: 500;
            letter-spacing: 0.5px;
            margin-bottom: 8px;
        }

        .feature-content p {
            font-size: 14px;
            color: #6A6A6A;
            letter-spacing: 0.3px;
            line-height: 1.6;
        }

        /* Specifications */
        .specs-section {
            margin-bottom: 48px;
        }

        .specs-grid {
            display: grid;
            gap: 16px;
        }

        .spec-item {
            display: flex;
            justify-content: space-between;
            padding: 16px 0;
            border-bottom: 1px solid #E8E8E5;
        }

        .spec-label {
            font-size: 14px;
            color: #8A8A8A;
            letter-spacing: 0.5px;
        }

        .spec-value {
            font-size: 14px;
            font-weight: 500;
            letter-spacing: 0.5px;
            text-align: right;
        }

        /* Description */
        .description-section {
            margin-bottom: 48px;
        }

        .description-text {
            font-size: 16px;
            line-height: 1.8;
            color: #4A4A4A;
            letter-spacing: 0.3px;
        }

        .description-text p {
            margin-bottom: 16px;
        }

        /* Included Services */
        .included-section {
            background-color: #FFFFFF;
            border: 1px solid #E8E8E5;
            padding: 40px;
            margin-bottom: 48px;
        }

        .included-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 24px;
            margin-top: 24px;
        }

        .included-item {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .included-item i {
            color: #1A1A1A;
        }

        .included-text {
            font-size: 15px;
            letter-spacing: 0.3px;
        }

        /* Trust Badges */
        .trust-badges {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 32px;
            padding: 48px 0;
            border-top: 1px solid #E8E8E5;
        }

        .badge {
            text-align: center;
        }

        .badge i {
            margin: 0 auto 16px;
            display: block;
        }

        .badge h4 {
            font-size: 15px;
            font-weight: 500;
            letter-spacing: 0.5px;
            margin-bottom: 8px;
        }

        .badge p {
            font-size: 13px;
            color: #6A6A6A;
            letter-spacing: 0.3px;
        }

        /* Footer */
        footer {
            background-color: #1A1A1A;
            color: #FFFFFF;
            padding: 64px 40px 32px;
            margin-top: 80px;
        }

        .footer-container {
            max-width: 1400px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 48px;
            margin-bottom: 48px;
        }

        .footer-section h4 {
            font-size: 14px;
            letter-spacing: 2px;
            text-transform: uppercase;
            margin-bottom: 24px;
            font-weight: 500;
        }

        .footer-links {
            display: flex;
            flex-direction: column;
            gap: 16px;
            font-size: 14px;
            color: #B8B8B8;
        }

        .footer-links a {
            color: #B8B8B8;
            text-decoration: none;
            cursor: pointer;
        }

        .footer-bottom {
            border-top: 1px solid #3A3A3A;
            padding-top: 32px;
            text-align: center;
            font-size: 13px;
            color: #6A6A6A;
            letter-spacing: 1px;
            max-width: 1400px;
            margin: 0 auto;
        }

        /* Responsive */
        @media (max-width: 968px) {
            .product-hero {
                grid-template-columns: 1fr;
                gap: 48px;
            }

            .hero-image {
                position: relative;
                top: 0;
            }

            .hero-content {
                padding-top: 0;
            }

            .product-title {
                font-size: 42px;
            }

            .product-price {
                font-size: 36px;
            }

            .included-grid {
                grid-template-columns: 1fr;
            }

            .trust-badges {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 768px) {
            .nav-container {
                padding: 20px 24px;
            }

            .breadcrumb {
                padding: 24px 24px 0;
            }

            .product-hero {
                padding: 32px 24px;
            }

            .product-title {
                font-size: 36px;
            }

            .product-price {
                font-size: 32px;
            }

            .cta-section {
                flex-direction: column;
            }

            .included-section {
                padding: 32px 24px;
            }

            footer {
                padding: 48px 24px 24px;
            }
        }
    </style>
</head>
