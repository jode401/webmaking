<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WebMaking - Premium Website Design</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
        <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Cormorant Garamond', serif;
            background-color: #FAFAF8;
            color: #1A1A1A;
            min-height: 100vh;
        }

        img {
            display: block;
        }

        button {
            font-family: 'Cormorant Garamond', serif;
        }

        /* Navigation */
        nav {
            position: sticky;
            top: 0;
            background-color: #FFFFFF;
            border-bottom: 1px solid #E8E8E5;
            z-index: 1000;
            backdrop-filter: blur(10px);
        }

        .nav-container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 24px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            font-size: 28px;
            font-weight: 300;
            letter-spacing: 3px;
            text-transform: uppercase;
        }

        .desktop-nav {
            display: flex;
            gap: 48px;
            font-size: 15px;
            letter-spacing: 1px;
            font-weight: 400;
        }

        .nav-btn {
            background: none;
            border: none;
            cursor: pointer;
            padding: 8px 0;
            color: #8A8A8A;
            border-bottom: 1px solid transparent;
            transition: all 0.3s ease;
            font-size: 15px;
            letter-spacing: 1px;
        }

        .nav-btn.active {
            color: #1A1A1A;
            border-bottom: 1px solid #1A1A1A;
        }

        .nav-icons {
            display: flex;
            gap: 28px;
            align-items: center;
        }

        .nav-icons i {
            cursor: pointer;
        }

        .mobile-menu-btn {
            background: none;
            border: none;
            cursor: pointer;
            padding: 8px;
            display: none;
        }

        .mobile-menu {
            padding: 24px 40px;
            border-top: 1px solid #E8E8E5;
            display: none;
        }

        .mobile-menu button {
            display: block;
            width: 100%;
            text-align: left;
            background: none;
            border: none;
            padding: 16px 0;
            font-size: 15px;
            cursor: pointer;
            letter-spacing: 1px;
            border-bottom: 1px solid #F5F5F3;
            color: #8A8A8A;
        }

        .mobile-menu button.active {
            color: #1A1A1A;
        }

        /* Hero Section */
        .hero {
            max-width: 1400px;
            margin: 0 auto;
            padding: 80px 40px;
            text-align: center;
        }

        .hero h1 {
            font-size: clamp(48px, 8vw, 96px);
            font-weight: 300;
            letter-spacing: 2px;
            margin: 0 0 24px 0;
            line-height: 1.1;
        }

        .hero p {
            font-size: clamp(16px, 2vw, 18px);
            color: #6A6A6A;
            max-width: 600px;
            margin: 0 auto 48px;
            letter-spacing: 0.5px;
            line-height: 1.8;
        }

        .cta-btn {
            padding: 16px 48px;
            background-color: #1A1A1A;
            color: #FFFFFF;
            border: none;
            cursor: pointer;
            font-size: 14px;
            letter-spacing: 2px;
            text-transform: uppercase;
            transition: all 0.3s ease;
        }

        .cta-btn:hover {
            background-color: #3A3A3A;
        }

        /* Trust Indicators */
        .trust-section {
            background-color: #FFFFFF;
            border-top: 1px solid #E8E8E5;
            border-bottom: 1px solid #E8E8E5;
            padding: 48px 40px;
        }

        .trust-container {
            max-width: 1400px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 48px;
        }

        .trust-item {
            text-align: center;
        }

        .trust-item i {
            margin: 0 auto 16px;
            display: block;
        }

        .trust-item h3 {
            font-size: 16px;
            font-weight: 500;
            letter-spacing: 1px;
            margin: 0 0 8px 0;
        }

        .trust-item p {
            font-size: 14px;
            color: #6A6A6A;
            margin: 0;
            letter-spacing: 0.3px;
        }

        /* Products Grid */
        .products-section {
            max-width: 1400px;
            margin: 0 auto;
            padding: 80px 40px;
        }

        .products-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 48px;
        }

        .product-card {
            background-color: #FFFFFF;
            border: 1px solid #E8E8E5;
            overflow: hidden;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .product-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 24px rgba(0,0,0,0.08);
        }

        .product-image {
            aspect-ratio: 1;
            overflow: hidden;
            background-color: #F5F5F3;
            position: relative;
        }

        .product-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s ease;
        }

        .product-card:hover .product-image img {
            transform: scale(1.05);
        }

        .product-content {
            padding: 32px 24px;
        }

        .product-category {
            font-size: 12px;
            color: #8A8A8A;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            margin-bottom: 8px;
        }

        .product-name {
            font-size: 20px;
            font-weight: 400;
            margin: 0 0 16px 0;
            letter-spacing: 0.5px;
        }

        .product-rating {
            display: flex;
            gap: 4px;
            margin-bottom: 16px;
        }

        .product-features {
            margin-bottom: 20px;
            padding-bottom: 20px;
            border-bottom: 1px solid #E8E8E5;
        }

        .feature-item {
            font-size: 13px;
            color: #6A6A6A;
            margin-bottom: 8px;
            letter-spacing: 0.3px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .product-price {
            font-size: 18px;
            font-weight: 500;
            letter-spacing: 0.5px;
            margin-bottom: 24px;
        }

        .product-btn {
            width: 100%;
            padding: 14px;
            background-color: #FFFFFF;
            color: #1A1A1A;
            border: 1px solid #1A1A1A;
            cursor: pointer;
            font-size: 13px;
            letter-spacing: 2px;
            text-transform: uppercase;
            transition: all 0.3s ease;
        }

        .product-btn:hover {
            background-color: #1A1A1A;
            color: #FFFFFF;
        }

        /* Footer */
        footer {
            background-color: #1A1A1A;
            color: #FFFFFF;
            padding: 64px 40px 32px;
        }

        .footer-container {
            max-width: 1400px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 48px;
            margin-bottom: 48px;
        }

        .footer-section h4 {
            font-size: 14px;
            letter-spacing: 2px;
            text-transform: uppercase;
            margin-bottom: 24px;
            font-weight: 500;
        }

        .footer-links {
            display: flex;
            flex-direction: column;
            gap: 16px;
            font-size: 14px;
            color: #B8B8B8;
        }

        .footer-links a {
            color: #B8B8B8;
            text-decoration: none;
            cursor: pointer;
        }

        .footer-bottom {
            border-top: 1px solid #3A3A3A;
            padding-top: 32px;
            text-align: center;
            font-size: 13px;
            color: #6A6A6A;
            letter-spacing: 1px;
            max-width: 1400px;
            margin: 0 auto;
        }

        .hidden {
            display: none !important;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .desktop-nav {
                display: none;
            }
            
            .mobile-menu-btn {
                display: block;
            }

            .mobile-menu.active {
                display: block;
            }

            .products-grid {
                grid-template-columns: 1fr;
            }

            .nav-container {
                padding: 20px 24px;
            }

            .hero {
                padding: 60px 24px;
            }

            .trust-section {
                padding: 40px 24px;
            }

            .products-section {
                padding: 60px 24px;
            }

            footer {
                padding: 48px 24px 24px;
            }
        }
    </style>
<nav>
        <div class="nav-container">
            <button class="mobile-menu-btn" onclick="toggleMobileMenu()">
                <i data-lucide="menu" width="24" height="24"></i>
            </button>

            <div class="logo">WebMaking</div>

            <div class="desktop-nav">
                <button class="nav-btn active" onclick="filterCategory('All')">All</button>
                <button class="nav-btn" onclick="filterCategory('Portfolio')">Portfolio</button>
                <button class="nav-btn" onclick="filterCategory('Reservation')">Reservation</button>
                <button class="nav-btn" onclick="filterCategory('Landing Pages')">Landing Pages</button>
            </div>

        </div>

        <div class="mobile-menu" id="mobileMenu">
            <button class="active" onclick="filterCategory('All'); closeMobileMenu();">All</button>
            <button onclick="filterCategory('Portfolio'); closeMobileMenu();">Portfolio</button>
            <button onclick="filterCategory('Reservation'); closeMobileMenu();">Reservation</button>
            <button onclick="filterCategory('Landing Pages'); closeMobileMenu();">Landing Pages</button>
        </div>
    </nav>
<%- body %>
<footer>
        <div class="footer-container">
            <div class="footer-section">
                <h4>Services</h4>
                <div class="footer-links">
                    <a>Custom Design</a>
                    <a>Development</a>
                    <a>Maintenance</a>
                </div>
            </div>
            <div class="footer-section">
                <h4>About</h4>
                <div class="footer-links">
                    <a href="https://jad-portfolio-pi.vercel.app/">Portfolio</a>
                </div>
            </div>
    
        </div>
        <div class="footer-bottom">
            © 2026 WebMaking. All rights reserved.
        </div>
    </footer>

<script>   // Toggle Mobile Menu
        function toggleMobileMenu() {
            const menu = document.getElementById('mobileMenu');
            const btn = document.querySelector('.mobile-menu-btn i');
            
            menu.classList.toggle('active');
            
            // Change icon
            if (menu.classList.contains('active')) {
                btn.setAttribute('data-lucide', 'x');
            } else {
                btn.setAttribute('data-lucide', 'menu');
            }
            lucide.createIcons();
        }

        function closeMobileMenu() {
            const menu = document.getElementById('mobileMenu');
            const btn = document.querySelector('.mobile-menu-btn i');
            
            menu.classList.remove('active');
            btn.setAttribute('data-lucide', 'menu');
            lucide.createIcons();
        }

        // Initialize
        document.addEventListener('DOMContentLoaded', () => {
            renderProducts();
            lucide.createIcons();
        });</script>